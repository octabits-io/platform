{
  "name": "@octabits-io/demo-server",
  "version": "0.0.8",
  "private": true,
  "type": "module",
  "description": "Contact-desk demo API — living documentation and pre-release validation harness for @octabits-io/framework",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun src/main.ts",
    "test": "bun test src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/provider": "^4.0.3",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@octabits-io/flow": "^0.12.0",
    "@octabits-io/framework": "workspace:*",
    "ai": "^7.0.34",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "typescript": "^7.0.2"
  }
}
