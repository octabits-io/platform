{
  "name": "@octabits-io/demo-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Contact-desk demo API — living documentation and pre-release validation harness for @octabits-io/framework",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@octabits-io/framework": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "typescript": "^7.0.2"
  }
}
