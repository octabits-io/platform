# Every value below is optional — the demo boots with these exact defaults.

PORT=3001
DATABASE_URL=postgres://demo:demo@localhost:5433/demo
PUBLIC_BASE_URL=http://localhost:3001
LOG_LEVEL=debug

# PII keys. The defaults are well-known DEV keys committed to the repo — the app
# refuses to boot with them when NODE_ENV=production.
# Generate real ones with:
#   bun -e 'import {generateIdentity} from "@octabits-io/framework/pii"; console.log(await generateIdentity())'
#   openssl rand -base64 32
DEMO_AGE_IDENTITY=AGE-SECRET-KEY-10ESX7NTKP6T2Z2DNW85R44PGPX0TR46N9J4YZXNR02J5MFAHY29SW92RCH
DEMO_BLIND_INDEX_KEY=demo-blind-index-key-not-for-production-use

MAIL_FROM_ADDRESS=noreply@demo.example
MAIL_FROM_NAME=Contact Desk

RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000
TRUSTED_PROXIES=

# Browser origins allowed to call this API (CSV). Defaults to the demo SPA.
CORS_ORIGINS=http://localhost:3100
