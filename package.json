{
  "name": "@octabits-io/platform",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "demo": "pnpm --parallel --filter @octabits-io/demo-server --filter @octabits-io/demo-web dev",
    "changeset": "changeset",
    "changeset:version": "GITHUB_TOKEN=$(passage show github/token) changeset version",
    "changeset:publish": "turbo run build && echo \"//registry.npmjs.org/:_authToken=$(passage show npm/token/octabits)\" > .npmrc && { changeset publish; s=$?; rm -f .npmrc; exit $s; }",
    "release": "bash scripts/release.sh"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "^1.3.14",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.9",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "zod": "^4.4.3"
  }
}
