{
  "name": "@octabits-io/captcha",
  "version": "0.3.0",
  "description": "Provider-agnostic captcha contract (challenge → redeem → verified-token → validate) with an ALTCHA proof-of-work implementation and a no-op for dev/test",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./altcha": {
      "types": "./dist/altcha.d.ts",
      "import": "./dist/altcha.js",
      "default": "./dist/altcha.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/captcha"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/captcha",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "@octabits-io/foundation": "workspace:^",
    "@types/bun": "^1.3.14",
    "altcha-lib": "^2.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.3.4"
  },
  "peerDependencies": {
    "@octabits-io/foundation": ">=0.3.0 <1",
    "altcha-lib": "^2",
    "typescript": "^5 || ^6",
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "altcha-lib": {
      "optional": true
    }
  }
}
