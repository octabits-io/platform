{
  "name": "@octabits-io/mail",
  "version": "0.3.0",
  "description": "Provider-agnostic mail transport contract with SMTP, Mailjet, Brevo, logger, and in-memory outbound transports",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./smtp": {
      "types": "./dist/smtp.d.ts",
      "import": "./dist/smtp.js",
      "default": "./dist/smtp.js"
    },
    "./mailjet": {
      "types": "./dist/mailjet.d.ts",
      "import": "./dist/mailjet.js",
      "default": "./dist/mailjet.js"
    },
    "./brevo": {
      "types": "./dist/brevo.d.ts",
      "import": "./dist/brevo.js",
      "default": "./dist/brevo.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/mail"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/mail",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "@octabits-io/foundation": "workspace:^",
    "@types/bun": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "node-mailjet": "^6.0.11",
    "nodemailer": "^9.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wretch": "^3.0.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@octabits-io/foundation": ">=0.2.0 <1",
    "node-mailjet": "^6",
    "nodemailer": "^7 || ^8 || ^9",
    "typescript": "^5 || ^6",
    "wretch": "^2 || ^3",
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "node-mailjet": {
      "optional": true
    },
    "nodemailer": {
      "optional": true
    },
    "wretch": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
