{
  "name": "@octabits-io/elysia",
  "version": "0.8.0",
  "description": "Reusable Elysia middleware & helpers: security headers, trusted-proxy client IP, error mapping, response schemas, rate limiting, health routes, app skeleton, and MCP harness",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsdown"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "default": "./dist/mcp.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@sinclair/typebox": ">= 0.34.0 < 1",
    "elysia-rate-limit": "^4.6.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/elysia"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/elysia",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octabits-io/foundation": "workspace:^",
    "elysia": "^1.4.29",
    "elysia-mcp": "^0.1.1",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octabits-io/foundation": ">=0.2.0 <1",
    "elysia": "^1.4.0",
    "elysia-mcp": "^0.1.1",
    "typescript": "^5 || ^6 || ^7",
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "elysia-mcp": {
      "optional": true
    }
  }
}
