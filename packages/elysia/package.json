{
  "name": "@octabits-io/elysia",
  "version": "0.2.0",
  "description": "Reusable Elysia middleware & helpers: security headers, trusted-proxy client IP, error mapping, and response schemas",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/elysia"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/elysia",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "elysia": "^1.4.29",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "elysia": "^1.4.0",
    "typescript": "^5 || ^6",
    "zod": "^4"
  }
}
