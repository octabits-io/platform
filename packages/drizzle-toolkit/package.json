{
  "name": "@octabits-io/drizzle-toolkit",
  "version": "0.9.0",
  "description": "Drizzle ORM toolkit: database error handling, pagination, factory, migrations, scoped CRUD, scoped config store, RLS scoping, idempotency, and generic scope schema primitives",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "default": "./dist/db/index.js"
    },
    "./factory": {
      "types": "./dist/factory/index.d.ts",
      "import": "./dist/factory/index.js",
      "default": "./dist/factory/index.js"
    },
    "./migrate": {
      "types": "./dist/migrate/index.d.ts",
      "import": "./dist/migrate/index.js",
      "default": "./dist/migrate/index.js"
    },
    "./scope": {
      "types": "./dist/scope/index.d.ts",
      "import": "./dist/scope/index.js",
      "default": "./dist/scope/index.js"
    },
    "./idempotency": {
      "types": "./dist/idempotency/index.d.ts",
      "import": "./dist/idempotency/index.js",
      "default": "./dist/idempotency/index.js"
    },
    "./crud": {
      "types": "./dist/crud/index.d.ts",
      "import": "./dist/crud/index.js",
      "default": "./dist/crud/index.js"
    },
    "./scoped-key-store": {
      "types": "./dist/scoped-key-store/index.d.ts",
      "import": "./dist/scoped-key-store/index.js",
      "default": "./dist/scoped-key-store/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./rls": {
      "types": "./dist/rls/index.d.ts",
      "import": "./dist/rls/index.js",
      "default": "./dist/rls/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/drizzle-toolkit"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/drizzle-toolkit",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@octabits-io/foundation": "workspace:^",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@octabits-io/foundation": ">=0.2.0 <1",
    "pg": "^8.22.0",
    "typescript": "^5 || ^6"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  }
}
