{
  "name": "@octabits-io/drizzle-toolkit",
  "version": "0.3.0",
  "description": "Drizzle ORM toolkit: database error handling, pagination, factory, migrations, multi-tenant schema primitives, and testcontainers test utilities",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./db": {
      "import": "./dist/db/index.js",
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./factory": {
      "import": "./dist/factory/index.js",
      "types": "./dist/factory/index.d.ts",
      "default": "./dist/factory/index.js"
    },
    "./migrate": {
      "import": "./dist/migrate/index.js",
      "types": "./dist/migrate/index.d.ts",
      "default": "./dist/migrate/index.js"
    },
    "./tenant": {
      "import": "./dist/tenant/index.js",
      "types": "./dist/tenant/index.d.ts",
      "default": "./dist/tenant/index.js"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./crud": {
      "import": "./dist/crud/index.js",
      "types": "./dist/crud/index.d.ts",
      "default": "./dist/crud/index.js"
    },
    "./rls": {
      "import": "./dist/rls/index.js",
      "types": "./dist/rls/index.d.ts",
      "default": "./dist/rls/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/drizzle-toolkit"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/drizzle-toolkit",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "dependencies": {
    "@octabits-io/foundation": "^0.3.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/pg": "^8.20.0",
    "testcontainers": "^12.0.4",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@testcontainers/postgresql": "^11 || ^12",
    "testcontainers": "^11 || ^12",
    "typescript": "^5 || ^6",
    "vitest": "^3 || ^4"
  },
  "peerDependenciesMeta": {
    "@testcontainers/postgresql": {
      "optional": true
    },
    "testcontainers": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  }
}
