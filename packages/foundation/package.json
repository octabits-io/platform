{
  "name": "@octabits-io/foundation",
  "version": "0.4.0",
  "description": "Core utilities: Result types, IoC container, logger, helpers, Zod config fragments, RBAC engine, and OIDC/JWT validation",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    "./result": {
      "types": "./dist/result/index.d.ts",
      "import": "./dist/result/index.js",
      "default": "./dist/result/index.js"
    },
    "./ioc": {
      "types": "./dist/ioc/index.d.ts",
      "import": "./dist/ioc/index.js",
      "default": "./dist/ioc/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js",
      "default": "./dist/logger/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./config-schema": {
      "types": "./dist/config-schema/index.d.ts",
      "import": "./dist/config-schema/index.js",
      "default": "./dist/config-schema/index.js"
    },
    "./rbac": {
      "types": "./dist/rbac/index.d.ts",
      "import": "./dist/rbac/index.js",
      "default": "./dist/rbac/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "default": "./dist/auth/index.js"
    },
    "./signing": {
      "types": "./dist/signing/index.d.ts",
      "import": "./dist/signing/index.js",
      "default": "./dist/signing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/foundation"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/foundation",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "jose": "^6.2.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "jose": "^6",
    "typescript": "^5 || ^6",
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "jose": {
      "optional": true
    }
  }
}
