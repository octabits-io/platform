{
  "name": "@octabits-io/ical",
  "version": "0.2.0",
  "description": "iCal ingestion: http/webcal fetcher with change-detection hashing, and a VEVENT/RRULE parser exposing raw event ranges with an optional day-blocking collapse layer",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/ical"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/ical",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "@octabits-io/foundation": "workspace:^",
    "@types/bun": "^1.3.14",
    "ical.js": "^2.2.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@octabits-io/foundation": ">=0.4.0 <1",
    "ical.js": "^2",
    "typescript": "^5 || ^6"
  }
}
