{
  "name": "@octabits-io/queue",
  "version": "0.1.0",
  "description": "pg-boss-backed queue base: lifecycle/monitoring facade plus a generic queue/worker/DLQ trio with Zod-validated payloads",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/queue"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/queue",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "dependencies": {
    "@octabits-io/foundation": "^0.2.0",
    "pg-boss": "^12.24.1"
  },
  "devDependencies": {
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6",
    "zod": "^4"
  }
}
