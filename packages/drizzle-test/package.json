{
  "name": "@octabits-io/drizzle-test",
  "version": "0.2.0",
  "description": "Drizzle ORM test utilities with testcontainers for PostgreSQL",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/drizzle-test"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/drizzle-test",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/pg": "^8.20.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "testcontainers": "^12.0.4",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@testcontainers/postgresql": "^11 || ^12",
    "drizzle-orm": "^0.45",
    "pg": "^8",
    "testcontainers": "^11 || ^12",
    "typescript": "^5 || ^6",
    "vitest": "^3 || ^4"
  }
}
