{
  "name": "@octabits-io/pii",
  "version": "0.2.0",
  "description": "PII encryption and tokenization utilities",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD-PARTY-NOTICES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/pii"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/pii",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0"
  },
  "devDependencies": {
    "vitest": "^4.1.9",
    "drizzle-orm": "^0.45.2",
    "@octabits-io/foundation": "workspace:^"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6",
    "zod": "^4",
    "drizzle-orm": "^0.45.2",
    "@octabits-io/foundation": ">=0.2.0 <1"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  }
}
