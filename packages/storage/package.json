{
  "name": "@octabits-io/storage",
  "version": "0.5.1",
  "description": "Namespaced blob storage contract with S3-compatible and raw-pg Postgres providers",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsdown"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./s3": {
      "types": "./dist/s3.d.ts",
      "import": "./dist/s3.js",
      "default": "./dist/s3.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js",
      "default": "./dist/postgres.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/storage"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/storage",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@octabits-io/foundation": "workspace:^",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "tsdown": "^0.22.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3",
    "@octabits-io/foundation": ">=0.2.0 <1",
    "pg": "^8.22.0",
    "typescript": "^5 || ^6 || ^7"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  }
}
