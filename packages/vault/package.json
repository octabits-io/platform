{
  "name": "@octabits-io/vault",
  "version": "0.3.0",
  "description": "Boot-time HashiCorp Vault secret loader — hydrates process.env from KV-v2 paths declared in a JSON manifest, before config loads. Plain fetch, no SDK.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/vault"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/vault",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6",
    "zod": "^4"
  }
}
