{
  "name": "@octabits-io/schema",
  "version": "0.1.0",
  "description": "Generic multi-tenant Drizzle schema primitives: base tenant, encryption-key, and config tables plus reusable column-sets",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/octabits-io/platform.git",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/octabits-io/platform/tree/main/packages/schema",
  "bugs": {
    "url": "https://github.com/octabits-io/platform/issues"
  },
  "devDependencies": {
    "drizzle-orm": "^0.45.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "typescript": "^5 || ^6"
  }
}
